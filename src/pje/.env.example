# src/pje/.env.example — copie para .env (NÃO versionar) e ajuste.
# Usado por pje.common.config.SETTINGS

# ----- Chrome debug (Parallels Windows) -----
# IP do Windows visto do Mac (Parallels Shared Network). Default: 10.211.55.3
CHROME_DEBUG_IP=10.211.55.3
# Porta CDP do Chrome em modo debug
CHROME_DEBUG_PORTA=9223

# ----- Destino dos PDFs baixados -----
# Default: ~/Desktop/ANALISADOR FINAL/processos
PROCESSOS_DIR=

# ----- Telegram (opcional) -----
# Bot @stemmiapericia_bot — pegue token em @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ----- Janela TJMG (PJE-009) -----
# PJe TJMG só responde estável entre 13h e 19h. Bypass com --forcar-horario.
TJMG_JANELA_INICIO=13
TJMG_JANELA_FIM=19

# ----- Motor browser default -----
# 'local' = Chromium Mac com perfil ~/.pje-browser-data (sem cert A3)
# 'remoto' = connect_over_cdp Chrome debug Windows (com cert A3)
# Override por execução: --motor local|remoto
PJE_MOTOR=local

# ----- Bypass forçado (debug) -----
# PJE_FORCAR_HORARIO=1   # ignora janela TJMG (só para debug)
