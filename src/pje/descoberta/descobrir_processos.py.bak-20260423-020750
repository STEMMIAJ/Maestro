def carregar_cnjs_conhecidos():
    """Carrega todos os CNJs conhecidos localmente."""
    cnjs = set()

    # De processos/*/FICHA.json
    if PROCESSOS_DIR.exists():
        for pasta in PROCESSOS_DIR.iterdir():
            if not pasta.is_dir():
                continue
            ficha = pasta / "FICHA.json"
            if ficha.exists():
                try:
                    data = json.loads(ficha.read_text(encoding="utf-8"))
                    cnj = data.get("cnj") or data.get("numero_cnj") or data.get("numero_processo", "")
                    if cnj and cnj != "None" and RE_CNJ.match(cnj):
                        cnjs.add(cnj)
                except (json.JSONDecodeError, OSError):
                    pass
            # CNJ no nome da pasta
            m = RE_CNJ.search(pasta.name)
            if m:
                cnjs.add(m.group())

    # De _pendentes_download.json
    if PENDENTES_JSON.exists():
        try:
            pend = json.loads(PENDENTES_JSON.read_text(encoding="utf-8"))
            for item in pend:
                if isinstance(item, str) and RE_CNJ.match(item):
                    cnjs.add(item)
        except (json.JSONDecodeError, OSError):
            pass

    return cnjs


def cnj_tem_pdf(cnj):
    """Verifica se um CNJ tem PDF baixado."""
    if not PROCESSOS_DIR.exists():
        return False
    for pasta in PROCESSOS_DIR.iterdir():
        if cnj in pasta.name or (pasta.is_dir() and (pasta / "FICHA.json").exists()):
            ficha = pasta / "FICHA.json"
            if ficha.exists():
                try:
                    data = json.loads(ficha.read_text(encoding="utf-8"))
                    c = data.get("cnj") or data.get("numero_cnj") or data.get("numero_processo", "")
                    if c == cnj:
                        return (pasta / "PROCESSO-ORIGINAL.pdf").exists() or any(pasta.glob("*.pdf"))
                except:
                    pass
    return False


