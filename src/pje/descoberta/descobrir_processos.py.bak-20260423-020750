def reconciliar(fontes_resultados, datajud_dados, cnjs_conhecidos):
    """Reconcilia resultados de todas as fontes."""
    log("RECONCILIAÇÃO: Cruzando fontes...")

    todos_cnjs = set(cnjs_conhecidos)
    fonte_por_cnj = {}

    # Mapear CNJs por fonte
    for resultado in fontes_resultados:
        fonte_nome = resultado.get("fonte", "?")
        for cnj in resultado.get("cnjs", []):
            if RE_CNJ.match(cnj):
                todos_cnjs.add(cnj)
                if cnj not in fonte_por_cnj:
                    fonte_por_cnj[cnj] = []
                fonte_por_cnj[cnj].append(fonte_nome)

    # Para CNJs conhecidos, marcar como "local"
    for cnj in cnjs_conhecidos:
        if cnj not in fonte_por_cnj:
            fonte_por_cnj[cnj] = []
        if "local" not in fonte_por_cnj[cnj]:
            fonte_por_cnj[cnj].append("local")

    # Classificar novos vs conhecidos
    novos = todos_cnjs - cnjs_conhecidos

    # Montar tabela consolidada
    processos = []
    for cnj in sorted(todos_cnjs):
        dj = datajud_dados.get(cnj, {})
        proc = {
            "numero_processo": cnj,
            "tribunal_origem": "TJMG",
            "classe": dj.get("classe", ""),
            "orgaoJulgador": dj.get("orgaoJulgador", ""),
            "grau": dj.get("grau", ""),
            "ultima_atualizacao": dj.get("dataHoraUltimaAtualizacao", ""),
            "total_movimentos": dj.get("total_movimentos", 0),
            "fontes": ", ".join(fonte_por_cnj.get(cnj, ["local"])),
            "consta_local": cnj in cnjs_conhecidos,
            "tem_pdf": cnj_tem_pdf(cnj),
            "novo": cnj in novos,
            "data_atualizacao_sistema": datetime.now().strftime("%Y-%m-%d"),
        }

        # Detectar tribunal pelo segmento CNJ
        partes = cnj.split(".")
        if len(partes) >= 3:
            j = partes[2] if len(partes) > 2 else ""
            if j == "5":
                proc["tribunal_origem"] = "TRF"
            elif j == "8":
                proc["tribunal_origem"] = "TJMG"

        processos.append(proc)

    return {
        "processos": processos,
        "total": len(processos),
        "conhecidos": len(cnjs_conhecidos),
        "novos": len(novos),
        "novos_cnjs": sorted(list(novos)),
    }


