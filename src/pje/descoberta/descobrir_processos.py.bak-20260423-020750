def fonte_dje_tjmg(dias=3):
    """Busca no DJe TJMG por nome/CPF/CRM."""
    log(f"FONTE 1: DJe TJMG (últimos {dias} dias)")

    try:
        sys.path.insert(0, str(SCRIPTS_DIR / "monitor-publicacoes"))
        from dje_tjmg import buscar_no_diario_html
    except ImportError as e:
        log(f"Erro importando dje_tjmg: {e}", "ERRO")
        return {"fonte": "dje_tjmg", "cnjs": [], "erro": str(e)}

    cnjs_encontrados = set()
    matches_total = 0
    hoje = datetime.now()

    for i in range(dias):
        d = hoje - timedelta(days=i)
        if d.weekday() == 6:
            continue
        data_str = d.strftime("%d/%m/%Y")
        matches = buscar_no_diario_html(data_str, modo_descoberta=True)
        matches_total += len(matches)
        for m in matches:
            for cnj in m.get("cnjs_no_contexto", []):
                cnjs_encontrados.add(cnj)

    resultado = {
        "fonte": "dje_tjmg",
        "cnjs": sorted(list(cnjs_encontrados)),
        "total_matches": matches_total,
        "dias_pesquisados": dias,
    }

    FONTES_DIR.mkdir(parents=True, exist_ok=True)
    (FONTES_DIR / "tjmg_dje_bruto.json").write_text(
        json.dumps(resultado, ensure_ascii=False, indent=2), encoding="utf-8"
    )

    log(f"DJe TJMG: {len(cnjs_encontrados)} CNJs, {matches_total} matches", "OK")
    return resultado


