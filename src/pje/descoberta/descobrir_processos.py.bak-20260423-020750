# Polimento: retry com backoff em erro de rede (tenacity). Se tenacity
# indisponível, decorator @retry vira no-op (definido no topo do arquivo).
if _TENACITY_OK:
    _datajud_retry = retry(
        stop=stop_after_attempt(3),
        wait=wait_exponential(multiplier=1, min=2, max=10),
        retry=retry_if_exception_type((urllib.error.URLError, TimeoutError, ConnectionError)),
        reraise=True,
    )
else:
    def _datajud_retry(f):
        return f


def _consultar_datajud_cnj_net(url, body, headers):
    """Chamada de rede isolada (para tenacity atuar só no IO)."""
    req = urllib.request.Request(url, data=body, headers=headers, method="POST")
    with urllib.request.urlopen(req, timeout=15) as resp:
        return json.loads(resp.read().decode("utf-8"))


_consultar_datajud_cnj_net = _datajud_retry(_consultar_datajud_cnj_net)


def consultar_datajud_cnj(cnj, tribunal="tjmg"):
    """Consulta um CNJ no DataJud. Retry automático em falha de rede."""
    url = DATAJUD_ENDPOINTS.get(tribunal)
    if not url:
        return None

    cnj_limpo = re.sub(r"[^\d]", "", cnj)
    body = json.dumps({
        "query": {"match": {"numeroProcesso": cnj_limpo}},
        "size": 1,
    }).encode("utf-8")
    headers = {
        "Content-Type": "application/json",
        "Authorization": f"APIKey {DATAJUD_KEY}",
    }

    try:
        data = _consultar_datajud_cnj_net(url, body, headers)
        hits = data.get("hits", {}).get("hits", [])
        if hits:
            return hits[0].get("_source", {})
    except Exception:
        pass
    return None


def fonte_datajud_enriquecer(cnjs):
    """Enriquece CNJs conhecidos com dados do DataJud."""
    log(f"FONTE 2: DataJud (enriquecendo {len(cnjs)} CNJs)")

    resultados = {}
    encontrados = 0

    for i, cnj in enumerate(sorted(cnjs)):
        # Detectar tribunal pelo segmento do CNJ
        m = RE_CNJ.match(cnj)
        if not m:
            continue

        tribunal = "tjmg"  # Default
        segmento = cnj.split(".")[2] if len(cnj.split(".")) > 2 else ""
        if segmento.startswith("5"):
            tribunal = "trf6"  # Federal

        dados = consultar_datajud_cnj(cnj, tribunal)
        if not dados and tribunal != "tjmg":
            dados = consultar_datajud_cnj(cnj, "tjmg")

        if dados:
            encontrados += 1
            resultados[cnj] = {
                "classe": dados.get("classe", {}).get("nome", ""),
                "orgaoJulgador": dados.get("orgaoJulgador", {}).get("nome", ""),
                "grau": dados.get("grau", ""),
                "dataHoraUltimaAtualizacao": dados.get("dataHoraUltimaAtualizacao", "")[:10],
                "total_movimentos": len(dados.get("movimentos", [])),
            }
        else:
            resultados[cnj] = {"erro": "Não encontrado"}

        if (i + 1) % 20 == 0:
            log(f"  DataJud: {i+1}/{len(cnjs)} ({encontrados} encontrados)", "INFO")

        time.sleep(0.3)

    FONTES_DIR.mkdir(parents=True, exist_ok=True)
    (FONTES_DIR / "datajud_enriquecido.json").write_text(
        json.dumps(resultados, ensure_ascii=False, indent=2), encoding="utf-8"
    )

    log(f"DataJud: {encontrados}/{len(cnjs)} encontrados", "OK")
    return resultados


