        if novos_prevalidados:
            log(f"Comunica PJe: {len(novos_prevalidados)} CNJs pré-validados (pulam validação)", "OK")

        novos_tjmg = {cnj for cnj in novos_a_validar if ".8.13." in cnj}
        novos_trf = {cnj for cnj in novos_a_validar if ".4.01." in cnj or ".4.06." in cnj}
        novos_outros = novos_a_validar - novos_tjmg - novos_trf

        descartados_total = set()

        # Validar TJMG via PJe Consulta Pública
        if novos_tjmg:
            confirmados_tjmg, descartados_tjmg = validar_cnjs_pje(novos_tjmg)
            descartados_total |= descartados_tjmg
        else:
            confirmados_tjmg = set()

        # Validar TRF via DataJud (verificar se perito aparece como parte)
        if novos_trf:
            confirmados_trf, descartados_trf = validar_cnjs_datajud(novos_trf)
            descartados_total |= descartados_trf
        else:
            confirmados_trf = set()

        novos = novos_prevalidados | confirmados_tjmg | confirmados_trf | novos_outros
        consolidado["novos"] = len(novos)
        consolidado["novos_cnjs"] = sorted(list(novos))
        consolidado["descartados_validacao"] = sorted(list(descartados_total))
        if descartados_total:
            log(f"Descartados na validação: {len(descartados_total)} CNJs")

    # ============================================================
    # CLASSIFICAÇÃO PERITO / PARTE / INDETERMINADO
    # (Passo 4 plano binary-gliding-pine — 2026-04-19)
    # Antes: 160 CNJs sem classificar, Dr. Jesus separava manualmente os
    # processos em que era parte (pessoais/familiares) vs perito.
    # Agora: blacklist Consulta Pública TJMG + DataJud estruturado decidem.
    # ============================================================
    try:
        from fontes.consulta_publica_tjmg import obter_blacklist
        from core.filtro_perito import (
            classificar_lote,
            PAPEL_PERITO,
            PAPEL_PARTE,
            PAPEL_INDETERMINADO,
        )

        log("Classificando CNJs em PERITO / PARTE / INDETERMINADO…")

        blacklist = obter_blacklist(verboso=True)
        log(f"Blacklist TJMG: {len(blacklist)} CNJs (Dr. Jesus é parte)")

        cnjs_lista = sorted(todos_cnjs)
        # datajud_dados tem `dados` enriquecidos já reduzidos; para classificar
        # precisamos do _source cru, mas aceita dict direto (filtro_perito lê
        # auxiliaresDaJustica/poloAtivo/poloPassivo em ambos formatos).
        classificacoes = classificar_lote(
            cnjs_lista,
            datajud_hits_by_cnj=datajud_dados,
            blacklist_tjmg=blacklist,
        )

        cnjs_perito = [c for c, r in classificacoes.items() if r["papel"] == PAPEL_PERITO]
        cnjs_indeterminado = [c for c, r in classificacoes.items() if r["papel"] == PAPEL_INDETERMINADO]
        cnjs_parte = [c for c, r in classificacoes.items() if r["papel"] == PAPEL_PARTE]

        data_str = datetime.now().strftime("%d%m%Y")
        CONSOLIDADO_DIR.mkdir(parents=True, exist_ok=True)

        def _gravar_csv_classificacao(nome, cnjs):
            path = CONSOLIDADO_DIR / f"{nome}_{data_str}.csv"
            with open(path, "w", newline="", encoding="utf-8") as f:
                writer = csv.writer(f)
                writer.writerow(["cnj", "papel", "razao", "sinais"])
                for c in sorted(cnjs):
                    r = classificacoes[c]
                    writer.writerow([
                        c,
                        r["papel"],
                        r["razao"],
                        json.dumps(r["sinais"], ensure_ascii=False),
                    ])
            return path

        csv_perito = _gravar_csv_classificacao("PERITO_CONFIRMADO", cnjs_perito)
        csv_indet = _gravar_csv_classificacao("INDETERMINADO", cnjs_indeterminado)
        csv_parte = _gravar_csv_classificacao("DESCARTE_PARTE", cnjs_parte)

        log(f"CSV PERITO: {csv_perito}", "OK")
        log(f"CSV INDETERMINADO: {csv_indet}", "OK")
        log(f"CSV DESCARTE_PARTE: {csv_parte}", "OK")

        total_classificado = len(cnjs_perito) + len(cnjs_indeterminado) + len(cnjs_parte)
        log(
            f"PERITO: {len(cnjs_perito)} | INDETERMINADO: {len(cnjs_indeterminado)} "
            f"| PARTE: {len(cnjs_parte)} | Total: {total_classificado}",
            "OK",
        )

        # Restringir downstream (pastas, pendentes, notificação) a PERITO + INDETERMINADO.
        # PARTE nunca vira pasta de processo nem entra no PUSH.
        cnjs_para_pipeline = set(cnjs_perito) | set(cnjs_indeterminado)
        novos = novos & cnjs_para_pipeline
        consolidado["novos"] = len(novos)
        consolidado["novos_cnjs"] = sorted(list(novos))
        consolidado["classificacao"] = {
            "perito": len(cnjs_perito),
            "indeterminado": len(cnjs_indeterminado),
            "parte": len(cnjs_parte),
        }
    except Exception as e:
        log(f"Erro na classificação perito/parte: {e}", "ERRO")

    # Criar pastas e atualizar pendentes para novos confirmados
    if novos:
        criar_pastas_novos(novos, datajud_dados)
        atualizar_pendentes(novos)

        # Notificar Telegram
        try:
            from notificar_telegram import enviar_descoberta
            enviar_descoberta(sorted(novos), consolidado["total"])
        except Exception:
            pass  # Token pode não estar configurado ainda

    # Salvar consolidado JSON
    if args.salvar:
        CONSOLIDADO_DIR.mkdir(parents=True, exist_ok=True)
        json_path = CONSOLIDADO_DIR / f"consolidacao_bruta_{datetime.now().strftime('%d%m%Y_%H%M')}.json"
        json_path.write_text(
            json.dumps(consolidado, ensure_ascii=False, indent=2), encoding="utf-8"
        )
        log(f"JSON: {json_path}", "OK")

    # Resumo final
    log("=" * 60)
    log(f"CONSOLIDAÇÃO: {consolidado['total']} únicos, {consolidado['novos']} NOVOS")
    if novos:
        log("NOVOS PROCESSOS:")
        for cnj in sorted(novos):
            dj = datajud_dados.get(cnj, {})
            classe = dj.get("classe", "?")
            orgao = dj.get("orgaoJulgador", "?")
            log(f"  {cnj} | {classe} | {orgao}", "NOVO")
    log("=" * 60)

    # JSON output
    if args.json:
        print(json.dumps(consolidado, ensure_ascii=False, indent=2))

    try:
        _novos = len(consolidado.get("novos", []))
        if _novos:
            rprint(f"[green]Descoberta concluída — {_novos} CNJs novos[/green]")
        else:
            rprint("[cyan]Descoberta concluída — nenhum CNJ novo[/cyan]")
    except Exception as _e:
        rprint(f"[red]Erro final descoberta: {_e}[/red]")

    salvar_log()


if __name__ == "__main__":
    main()
