                ctx = m.get("contexto", "").upper()
                cnjs_match = m.get("cnjs_no_contexto", [])

                # CNJ direto (termo é um CNJ que já monitoramos) = confiável
                if RE_CNJ.match(termo):
                    cnjs_confiaveis.update(cnjs_match)
                # CPF ou CRM = confiável
                elif "127.858.856" in termo or "12785885660" in termo or "92.148" in termo or "92148" in termo:
                    cnjs_confiaveis.update(cnjs_match)
                # JESUS EDUARDO = confiável
                elif "JESUS" in termo.upper():
