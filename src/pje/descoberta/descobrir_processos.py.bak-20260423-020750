def gerar_csv(consolidado):
    """Gera CSV consolidado."""
    CONSOLIDADO_DIR.mkdir(parents=True, exist_ok=True)
    data_str = datetime.now().strftime("%d%m%Y")
    csv_path = CONSOLIDADO_DIR / f"RELATORIO_PROCESSOS_{data_str}.csv"

    processos = consolidado.get("processos", [])
    if not processos:
        return csv_path

    campos = [
        "numero_processo", "tribunal_origem", "classe", "orgaoJulgador",
        "grau", "ultima_atualizacao", "total_movimentos", "fontes",
        "consta_local", "tem_pdf", "novo", "data_atualizacao_sistema",
    ]

    with open(csv_path, "w", newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(f, fieldnames=campos, extrasaction="ignore")
        writer.writeheader()
        writer.writerows(processos)

    return csv_path


