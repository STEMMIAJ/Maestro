# ============================================================

DJEN_BASE = "https://comunicaapi.pje.jus.br/api/v1/comunicacao"
DJEN_TRIBUNAIS = ["TJMG", "TRF6"]
DJEN_FILTRO_TEXTO = re.compile(r'PERIT|NOMEADO|LAUDO|EXPERT', re.IGNORECASE)


def _buscar_djen_tribunal(tribunal, nome="JESUS EDUARDO", itens=100):
    """Busca comunicações em um tribunal via API pública DJEN."""
    params = urllib.parse.urlencode({
        "nomeParte": nome,
        "siglaTribunal": tribunal,
        "itensPorPagina": itens,
    })
    url = f"{DJEN_BASE}?{params}"

    req = urllib.request.Request(url, headers={"Accept": "application/json"})
    try:
        with urllib.request.urlopen(req, timeout=30, context=SSL_CTX) as resp:
            # Respeitar rate limit
            remaining = resp.headers.get("x-ratelimit-remaining")
            if remaining and int(remaining) < 3:
                log(f"DJEN {tribunal}: rate limit baixo ({remaining}), aguardando 5s", "AVISO")
                time.sleep(5)
            return json.loads(resp.read().decode("utf-8"))
    except urllib.error.HTTPError as e:
        if e.code == 429:
            log(f"DJEN {tribunal}: rate limited (429), aguardando 60s", "AVISO")
            time.sleep(60)
            try:
                with urllib.request.urlopen(req, timeout=30, context=SSL_CTX) as resp:
                    return json.loads(resp.read().decode("utf-8"))
            except Exception:
                pass
        return None
    except Exception:
        return None


def fonte_comunica_pje(dias=30):
    """Descobre processos via API DJEN pública (TJMG + TRF6)."""
    log("FONTE 6: DJEN API pública (TJMG + TRF6)")

    cnjs_encontrados = set()
    total_comunicacoes = 0

    # Buscar em paralelo nos dois tribunais
    with ThreadPoolExecutor(max_workers=2) as pool:
        futures = {pool.submit(_buscar_djen_tribunal, trib): trib for trib in DJEN_TRIBUNAIS}
        for future in as_completed(futures):
            trib = futures[future]
            try:
                data = future.result()
                if not data:
                    log(f"DJEN {trib}: sem resposta", "AVISO")
                    continue

                items = data.get("items", [])
                total_comunicacoes += len(items)
                trib_cnjs = 0

                for item in items:
                    texto = item.get("texto", "").upper()
                    # Filtrar por menção a perito/nomeação (eliminar homônimos)
                    if not DJEN_FILTRO_TEXTO.search(texto):
                        continue

                    num = item.get("numero_processo", "")
                    if len(num) == 20:
                        cnj = f"{num[:7]}-{num[7:9]}.{num[9:13]}.{num[13]}.{num[14:16]}.{num[16:]}"
                    else:
                        cnj = num
                    if RE_CNJ.match(cnj):
                        cnjs_encontrados.add(cnj)
                        trib_cnjs += 1

                log(f"DJEN {trib}: {trib_cnjs} CNJs periciais (de {len(items)} comunicações)", "OK")

            except Exception as e:
                log(f"DJEN {trib}: {e}", "ERRO")

    # Pausa entre fonte 6 e próximas operações (respeitar rate limit)
    time.sleep(0.5)

    resultado = {
        "fonte": "djen_api",
        "cnjs": sorted(list(cnjs_encontrados)),
        "total": len(cnjs_encontrados),
        "comunicacoes": total_comunicacoes,
        "tribunais": DJEN_TRIBUNAIS,
    }

    FONTES_DIR.mkdir(parents=True, exist_ok=True)
    (FONTES_DIR / "comunica_pje_bruto.json").write_text(
        json.dumps(resultado, ensure_ascii=False, indent=2), encoding="utf-8"
    )

    log(f"DJEN total: {len(cnjs_encontrados)} CNJs periciais (de {total_comunicacoes} comunicações)", "OK")
    return resultado


# ============================================================
# VALIDAÇÃO PÓS-DESCOBERTA (PJe Consulta Pública por CNJ)
# ============================================================

def validar_cnjs_pje(cnjs_novos, max_validacoes=50):
    """
    Valida CNJs novos consultando PJe Consulta Pública por CNJ.
    Verifica se "JESUS EDUARDO" ou CPF aparece como parte/perito.

    Returns:
        (confirmados, descartados) — dois sets de CNJs
    """
    if not cnjs_novos:
        return set(), set()

    log(f"Validando {len(cnjs_novos)} CNJs novos via PJe Consulta Pública...")

    confirmados = set()
    descartados = set()
    erros = 0

    try:
        import requests as req
    except ImportError:
        log("requests não disponível — pulando validação", "AVISO")
        return set(cnjs_novos), set()  # Assume todos válidos

    url_base = "https://pje-consulta-publica.tjmg.jus.br"

    _lista = sorted(cnjs_novos)[:max_validacoes]
    for i, cnj in enumerate(tqdm(_lista, desc="Validando CNJs PJe", unit="cnj")):
        try:
            # Buscar processo por CNJ na consulta pública
            sess = req.Session()
            sess.verify = False

            # GET página inicial para ViewState
            resp = sess.get(f"{url_base}/pje/ConsultaPublica/listView.seam", timeout=15)
            if resp.status_code != 200:
                erros += 1
                continue

            # Extrair ViewState
            import re as re_mod
            vs_match = re_mod.search(r'id="javax\.faces\.ViewState"[^>]*value="([^"]*)"', resp.text)
            if not vs_match:
                vs_match = re_mod.search(r'name="javax\.faces\.ViewState"[^>]*value="([^"]*)"', resp.text)
            view_state = vs_match.group(1) if vs_match else "j_id1"

            # Formatar CNJ para campo de busca
            cnj_limpo = cnj.replace("-", "").replace(".", "")

            # POST busca por número do processo
            data = {
                "fPP": "fPP",
                "autoScroll": "",
                "fPP:numProcesso-inputNumeroProcessoDecoration:numProcesso-inputNumeroProcesso": cnj_limpo,
                "fPP:searchProcessos": "Pesquisar",
                "fPP:j_idcl": "",
                "fPP:_link_hidden_": "",
                "javax.faces.ViewState": view_state,
            }

            resp2 = sess.post(
                f"{url_base}/pje/ConsultaPublica/listView.seam",
                data=data, timeout=15,
            )

            if resp2.status_code == 200:
                texto = resp2.text.upper()
                # Verificar se o perito aparece nos resultados
                if "JESUS EDUARDO" in texto or PERITO_CPF in texto or PERITO_CPF_FMT.replace(".", "").replace("-", "") in texto:
                    confirmados.add(cnj)
                    log(f"  ✓ {cnj} — CONFIRMADO", "OK")
                else:
                    descartados.add(cnj)
                    log(f"  ✗ {cnj} — perito não encontrado", "AVISO")
            else:
                erros += 1

            time.sleep(0.5)  # Rate limit

        except Exception:
            erros += 1
            continue

    # CNJs não validados (acima do max) ficam como DESCARTADOS (não dar benefício da dúvida)
    nao_validados = set(cnjs_novos) - confirmados - descartados
    if nao_validados:
        log(f"  {len(nao_validados)} CNJs não validados (acima do limite) — descartados por precaução", "AVISO")
        descartados |= nao_validados

    log(f"Validação: {len(confirmados)} confirmados, {len(descartados)} descartados, {erros} erros", "OK")
    return confirmados, descartados


# ============================================================
# VALIDAÇÃO TRF VIA DATAJUD (verifica se perito é parte)
# ============================================================

def validar_cnjs_datajud(cnjs_novos, max_validacoes=50):
    """
    Valida CNJs federais via DataJud — verifica se o nome do perito
    aparece nas partes do processo.

    Returns:
        (confirmados, descartados) — dois sets de CNJs
    """
    if not cnjs_novos:
        return set(), set()

    log(f"Validando {len(cnjs_novos)} CNJs federais via DataJud...")

    confirmados = set()
    descartados = set()
    termos_perito = ["JESUS EDUARDO", "NOLETO DA PENHA", PERITO_CPF]

    _lista_dj = sorted(cnjs_novos)[:max_validacoes]
    for i, cnj in enumerate(tqdm(_lista_dj, desc="Validando CNJs DataJud", unit="cnj")):
        # Detectar tribunal
        tribunal = "trf6" if ".4.06." in cnj else "tjmg"

        dados = consultar_datajud_cnj(cnj, tribunal)
        if not dados:
            # Tentar outros tribunais
            for t in ["trf6", "tjmg", "trt3"]:
                if t != tribunal:
                    dados = consultar_datajud_cnj(cnj, t)
                    if dados:
                        break

        if dados:
            # Serializar todo o JSON e procurar nome do perito
            texto = json.dumps(dados, ensure_ascii=False).upper()
            encontrado = any(t.upper() in texto for t in termos_perito)

            if encontrado:
                confirmados.add(cnj)
                classe = dados.get("classe", {}).get("nome", "?")
                log(f"  ✓ {cnj} — CONFIRMADO ({classe})", "OK")
            else:
                descartados.add(cnj)
                classe = dados.get("classe", {}).get("nome", "?")
                log(f"  ✗ {cnj} — perito não encontrado ({classe})", "AVISO")
        else:
            # Não encontrado no DataJud — descartar
            descartados.add(cnj)
            log(f"  ✗ {cnj} — não encontrado no DataJud", "AVISO")

        time.sleep(0.3)

    # CNJs acima do limite — descartar por precaução
    nao_validados = set(cnjs_novos) - confirmados - descartados
    if nao_validados:
        descartados |= nao_validados
        log(f"  {len(nao_validados)} CNJs TRF não validados — descartados", "AVISO")

    log(f"Validação TRF: {len(confirmados)} confirmados, {len(descartados)} descartados", "OK")
    return confirmados, descartados


