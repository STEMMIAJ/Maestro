# ─── Utilitários ─────────────────────────────────────────────────────────────

def log(msg, nivel="INFO"):
    """Loga no terminal e no arquivo."""
    ts = datetime.now().strftime("%H:%M:%S")
    linha = f"[{ts}] [{nivel}] {msg}"
    print(linha)
    try:
        with open(LOG_FILE, "a", encoding="utf-8") as f:
            f.write(f"[{datetime.now().isoformat()}] [{nivel}] {msg}\n")
    except Exception:
        pass


def rodar(cmd, timeout=300, capturar=True):
    """Roda comando externo, retorna (sucesso, stdout)."""
    try:
        r = subprocess.run(
            cmd, capture_output=capturar, text=True, timeout=timeout,
            cwd=str(SCRIPTS_DIR)
        )
        return r.returncode == 0, r.stdout if capturar else ""
    except subprocess.TimeoutExpired:
        return False, f"TIMEOUT ({timeout}s)"
    except Exception as e:
        return False, str(e)


def checar_porta(porta):
    """Verifica se Chrome CDP está respondendo na porta."""
    ok, out = rodar(
        ["curl", "-s", "-o", "/dev/null", "-w", "%{http_code}",
         f"http://localhost:{porta}/json/version"],
        timeout=5
    )
    return ok and out.strip() == "200"


def checar_parallels():
    """Verifica se Parallels está rodando com Windows."""
    ok, out = rodar(["prlctl", "list", "-f"], timeout=5)
    if ok and "running" in out.lower():
        # Tenta extrair IP
        match = re.search(r"(10\.\d+\.\d+\.\d+)", out)
        ip = match.group(1) if match else "10.211.55.3"
        return True, ip
    return False, None


def extrair_cnj(texto):
    """Extrai número CNJ de um texto."""
    m = re.search(r"\d{7}-\d{2}\.\d{4}\.\d\.\d{2}\.\d{4}", texto)
    return m.group(0) if m else None


def md5_arquivo(caminho):
    """Calcula MD5 de um arquivo."""
    h = hashlib.md5()
    with open(caminho, "rb") as f:
        for bloco in iter(lambda: f.read(8192), b""):
            h.update(bloco)
    return h.hexdigest()


def ler_ficha(pasta):
    """Lê FICHA.json de uma pasta de processo."""
    ficha_path = Path(pasta) / "FICHA.json"
    if ficha_path.exists():
        try:
            return json.loads(ficha_path.read_text(encoding="utf-8"))
        except Exception:
            pass
    return {}


def salvar_ficha(pasta, ficha):
    """Salva FICHA.json."""
    ficha_path = Path(pasta) / "FICHA.json"
    ficha_path.write_text(
        json.dumps(ficha, indent=2, ensure_ascii=False),
        encoding="utf-8"
    )


# ─── Importar PDFs do Windows (_downloads_temp) ─────────────────────────────

def importar_downloads_temp():
    """Importa PDFs baixados pelo Windows de _downloads_temp para processos/."""
    log("═══ IMPORTAR PDFs DE _downloads_temp ═══")

    if not DOWNLOADS_TEMP.is_dir():
        log("  Pasta _downloads_temp/ não existe — nada a importar")
        return []

    importados = []
    for subpasta in sorted(DOWNLOADS_TEMP.iterdir()):
        if not subpasta.is_dir():
            continue
        pdf = subpasta / "autos-completos.pdf"
        if not pdf.exists():
            continue

        cnj = extrair_cnj(subpasta.name) or subpasta.name
        pasta_dest = PROCESSOS_DIR / cnj
        pasta_dest.mkdir(parents=True, exist_ok=True)

        pdf_destino = pasta_dest / "autos-completos.pdf"

        # Backup se já existir
        if pdf_destino.exists():
            hash_atual = md5_arquivo(str(pdf_destino))
            hash_novo = md5_arquivo(str(pdf))
            if hash_atual == hash_novo:
                log(f"  = {cnj}: PDF idêntico, pulando")
                continue
            data_backup = datetime.now().strftime("%Y-%m-%d")
            backup = pasta_dest / f"autos-completos-{data_backup}.pdf"
            shutil.move(str(pdf_destino), str(backup))
            log(f"  ↻ {cnj}: versão anterior salva como {backup.name}")

        shutil.move(str(pdf), str(pdf_destino))
        log(f"  → {cnj}: PDF importado")

        # Extrair texto
        txt = pasta_dest / "TEXTO-EXTRAIDO.txt"
        ok, _ = rodar(["pdftotext", "-layout", str(pdf_destino), str(txt)], timeout=120)
        if ok and txt.exists():
            log(f"    Texto extraído ({txt.stat().st_size // 1024} KB)")

        # Atualizar FICHA.json
        ficha = ler_ficha(pasta_dest)
        ficha["data_download"] = datetime.now().isoformat()
        ficha["hash_pdf"] = md5_arquivo(str(pdf_destino))
        ficha["tamanho_pdf_mb"] = round(pdf_destino.stat().st_size / 1048576, 1)
        salvar_ficha(pasta_dest, ficha)

        importados.append({
            "cnj": cnj,
            "pasta": str(pasta_dest),
            "tamanho_mb": round(pdf_destino.stat().st_size / 1048576, 1),
        })

        # Limpar subpasta temp
        shutil.rmtree(subpasta, ignore_errors=True)

    # Limpar pasta temp se vazia
    if DOWNLOADS_TEMP.exists() and not any(DOWNLOADS_TEMP.iterdir()):
        DOWNLOADS_TEMP.rmdir()

    log(f"  {len(importados)} processos importados de _downloads_temp")
    return importados


def exportar_pendentes():
    """Salva lista de CNJs sem PDF em _pendentes_download.json para pipeline Windows."""
    log("═══ EXPORTAR PENDENTES PARA WINDOWS ═══")

    cnjs_sem_pdf = []
    if PROCESSOS_DIR.is_dir():
        for pasta in sorted(PROCESSOS_DIR.iterdir()):
            if not pasta.is_dir() or pasta.name.startswith("."):
                continue
            cnj = extrair_cnj(pasta.name)
            if not cnj:
                continue
            tem_pdf = any(pasta.glob("*.pdf"))
            if not tem_pdf:
                cnjs_sem_pdf.append(cnj)

    PENDENTES_JSON.write_text(
        json.dumps(cnjs_sem_pdf, ensure_ascii=False, indent=2),
        encoding="utf-8"
    )
    log(f"  {len(cnjs_sem_pdf)} processos sem PDF exportados para {PENDENTES_JSON.name}")
    log("  Agora rode sincronizar-pje-windows.cmd no Windows para baixar.")
    log("  Depois rode: python3 orquestrador_noturno.py --importar")
    return cnjs_sem_pdf


def diagnostico_detalhado(diag):
    """Diagnóstico expandido: pendentes, downloads temp, flag, ferramentas."""
    log("─── DIAGNÓSTICO DETALHADO ───")

    # Pendentes JSON
    if PENDENTES_JSON.exists():
        try:
            pendentes = json.loads(PENDENTES_JSON.read_text(encoding="utf-8"))
            if pendentes:
                log(f"  ✓ Pendentes JSON: {len(pendentes)} processos")
            else:
                log("  ⚠ Pendentes JSON: vazio (rode --exportar-pendentes)")
        except Exception:
            log("  ✗ Pendentes JSON: arquivo inválido")
    else:
        log("  ⚠ Pendentes JSON: não existe (rode --exportar-pendentes)")

    # Downloads temp
    if DOWNLOADS_TEMP.exists():
        pdfs = list(DOWNLOADS_TEMP.glob("*/autos-completos.pdf"))
        if pdfs:
            log(f"  ✓ Downloads temp: {len(pdfs)} PDFs prontos (rode --importar)")
        else:
            log("  · Downloads temp: pasta existe mas sem PDFs")
    else:
        log("  · Downloads temp: não existe")

    # Flag de conclusão
    if DOWNLOAD_FLAG.exists():
        conteudo = DOWNLOAD_FLAG.read_text(encoding="utf-8", errors="ignore").strip()
        log(f"  ✓ Flag de conclusão: {conteudo}")
    else:
        log("  · Flag de conclusão: não existe")

    # Processos com/sem PDF
    total = com_pdf = sem_pdf = 0
    if PROCESSOS_DIR.is_dir():
        for item in PROCESSOS_DIR.iterdir():
            if not item.is_dir() or item.name.startswith(".") or item.name.startswith("Perícia"):
                continue
            total += 1
            resolved = item.resolve()
            if any((resolved / n).exists() for n in ["autos-completos.pdf", "PROCESSO-ORIGINAL.pdf"]):
                com_pdf += 1
            else:
                sem_pdf += 1

    log(f"  Processos: {total} total, {com_pdf} com PDF, {sem_pdf} sem PDF")

    # Ferramentas
    for cmd in ["pdftotext", "pdfinfo"]:
        path = shutil.which(cmd)
        if path:
            log(f"  ✓ {cmd}: {path}")
        else:
            log(f"  ✗ {cmd}: NÃO encontrado (brew install poppler)")

    diag["pendentes_json"] = PENDENTES_JSON.exists()
    diag["downloads_temp_pdfs"] = len(list(DOWNLOADS_TEMP.glob("*/autos-completos.pdf"))) if DOWNLOADS_TEMP.exists() else 0
    diag["processos_com_pdf"] = com_pdf
    diag["processos_sem_pdf"] = sem_pdf


