# ─── ETAPA 4: Verificar movimentações (DataJud) ─────────────────────────────

def etapa_verificar_movimentacoes():
    """Compara movimentações via DataJud com PDFs locais."""
    log("═══ ETAPA 4: VERIFICAR MOVIMENTAÇÕES ═══")

    desatualizados = []

    if not PROCESSOS_DIR.is_dir():
        log("  Pasta processos/ não encontrada", "WARN")
        return desatualizados

    for pasta in sorted(PROCESSOS_DIR.iterdir()):
        if not pasta.is_dir() or pasta.name.startswith("."):
            continue

        ficha = ler_ficha(pasta)
        cnj = ficha.get("cnj") or extrair_cnj(pasta.name)
        if not cnj:
            continue

        # Só verifica processos que já têm PDF
        pdfs = list(pasta.glob("*.pdf"))
        if not pdfs:
            continue

        # Data do PDF mais recente
        pdf_mais_recente = max(pdfs, key=lambda p: p.stat().st_mtime)
        data_pdf = datetime.fromtimestamp(pdf_mais_recente.stat().st_mtime)

        # Consultar DataJud (API pública, sem browser)
        try:
            cnj_limpo = re.sub(r"[^\d]", "", cnj)
            ok, out = rodar(
                ["curl", "-s", "-f",
                 f"https://api-publica.datajud.cnj.jus.br/api_publica_tjmg/_search",
                 "-H", "Content-Type: application/json",
                 "-H", "Authorization: APIKey cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw==",
                 "-d", json.dumps({
                     "query": {"match": {"numeroProcesso": cnj_limpo}},
                     "size": 1,
                     "sort": [{"dataHoraUltimaAtualizacao": {"order": "desc"}}]
                 })],
                timeout=15
            )
            if ok and out.strip():
                resp = json.loads(out)
                hits = resp.get("hits", {}).get("hits", [])
                if hits:
                    src = hits[0].get("_source", {})
                    ultima_mov = src.get("dataHoraUltimaAtualizacao", "")
                    if ultima_mov:
                        # Formato ISO ou YYYY-MM-DD...
                        data_mov = datetime.fromisoformat(
                            ultima_mov.replace("Z", "+00:00").split("+")[0]
                        )
                        if data_mov > data_pdf + timedelta(hours=1):
                            ficha["_desatualizado"] = True
                            ficha["_ultima_movimentacao_datajud"] = ultima_mov
                            ficha["_data_pdf_local"] = data_pdf.isoformat()
                            salvar_ficha(pasta, ficha)
                            desatualizados.append({
                                "cnj": cnj,
                                "pasta": str(pasta),
                                "data_pdf": data_pdf.isoformat(),
                                "data_movimentacao": ultima_mov
                            })
                            log(f"  ↻ Desatualizado: {cnj}")
        except Exception as e:
            # DataJud falha silenciosa — não é crítico
            pass

    log(f"  {len(desatualizados)} processos desatualizados")

    saida = SCRIPTS_DIR / "_processos_desatualizados.json"
    saida.write_text(json.dumps(desatualizados, indent=2, ensure_ascii=False), encoding="utf-8")

    return desatualizados


# ─── ETAPA 5: Gerar lista de downloads pendentes ────────────────────────────

def etapa_pendentes(nomeacoes_aj, nomeacoes_ajg, desatualizados):
    """Gera lista unificada de CNJs que precisam de download."""
    log("═══ ETAPA 5: PENDENTES DE DOWNLOAD ═══")

    cnjs = {}

    # CNJs de nomeações sem PDF
    for nom in nomeacoes_aj + nomeacoes_ajg:
        cnj = nom.get("numero_processo_cnj", "")
        if not cnj:
            continue
        pasta = PROCESSOS_DIR / cnj
        tem_pdf = any(pasta.glob("*.pdf")) if pasta.exists() else False
        if not tem_pdf:
            cnjs[cnj] = {"motivo": "PENDENTE-PDF", "origem": nom.get("_origem", "?")}

    # CNJs desatualizados
    for d in desatualizados:
        cnj = d["cnj"]
        if cnj not in cnjs:
            cnjs[cnj] = {"motivo": "DESATUALIZADO", "origem": "DataJud"}

    # Processos existentes sem PDF (varredura geral)
    if PROCESSOS_DIR.is_dir():
        for pasta in PROCESSOS_DIR.iterdir():
            if not pasta.is_dir() or pasta.name.startswith("."):
                continue
            cnj = extrair_cnj(pasta.name)
            if not cnj:
                continue
            tem_pdf = any(pasta.glob("*.pdf"))
            if not tem_pdf and cnj not in cnjs:
                cnjs[cnj] = {"motivo": "PENDENTE-PDF", "origem": "local"}

    pendentes = [{"cnj": k, **v} for k, v in cnjs.items()]
    log(f"  {len(pendentes)} downloads pendentes")

    saida = SCRIPTS_DIR / "_pendentes_download.json"
    saida.write_text(json.dumps(pendentes, indent=2, ensure_ascii=False), encoding="utf-8")

    return pendentes


# ─── ETAPA 6: Baixar PDFs do PJe ────────────────────────────────────────────

def etapa_baixar(pendentes, diag, max_downloads=None, dry_run=False):
    """Baixa PDFs do PJe via CDP."""
    log("═══ ETAPA 6: BAIXAR PDFs DO PJe ═══")

    if not pendentes:
        log("  Nenhum download pendente")
        return []

    if dry_run:
        log(f"  [DRY-RUN] Baixaria {len(pendentes)} processos")
        return [{"cnj": p["cnj"], "status": "dry-run"} for p in pendentes]

    if not diag.get("pode_baixar"):
        log("  ⚠ Nenhum Chrome PJe disponível — pulando downloads", "WARN")
        return []

    # Determinar porta e IP
    if diag.get("chrome_pje_win"):
        ip = diag.get("parallels_ip", "10.211.55.3")
        porta = PORTA_PJE_WIN
        log(f"  Usando Chrome Windows ({ip}:{porta})")
    else:
        ip = "localhost"
        porta = PORTA_PJE_MAC
        log(f"  Usando Chrome Mac (localhost:{porta})")

    # Limitar downloads
    lista = pendentes[:max_downloads] if max_downloads else pendentes
    cnjs = [p["cnj"] for p in lista]
    log(f"  Baixando {len(cnjs)} processos...")

    # Encontrar baixar_pje.py
    script_pje = str(BAIXAR_PJE if BAIXAR_PJE.exists() else BAIXAR_PJE_LOCAL)

    resultados = []
    for i, cnj in enumerate(cnjs, 1):
        log(f"  [{i}/{len(cnjs)}] {cnj}")
        ok, out = rodar(
            ["python3", script_pje,
             "--ip", ip,
             "--porta", str(porta),
             "--processos", cnj,
             "--retomar",
             "--saida", str(SCRIPTS_DIR / "_downloads_temp")],
            timeout=300  # 5 min por processo
        )
        resultados.append({
            "cnj": cnj,
            "status": "ok" if ok else "erro",
            "detalhe": out[:200] if not ok else ""
        })
        if ok:
            log(f"    ✓ Baixado")
        else:
            log(f"    ✗ Falha: {out[:100]}", "ERROR")

    return resultados


# ─── ETAPA 7: Importar + Processar ──────────────────────────────────────────

def etapa_importar(resultados_download, dry_run=False):
    """Move PDFs para processos/, extrai texto, renomeia pastas."""
    log("═══ ETAPA 7: IMPORTAR + PROCESSAR ═══")

    downloads_dir = SCRIPTS_DIR / "_downloads_temp"
    importados = []

    if dry_run:
        log("  [DRY-RUN] Pulando importação")
        return importados

    if not downloads_dir.is_dir():
        log("  Pasta _downloads_temp/ não existe — nada a importar")
        return importados

    for item in sorted(downloads_dir.iterdir()):
        if not item.is_dir():
            continue

        cnj = extrair_cnj(item.name) or item.name
        pasta_dest = PROCESSOS_DIR / cnj

        # Criar pasta se não existe
        pasta_dest.mkdir(parents=True, exist_ok=True)

        # Mover PDFs
        for pdf in item.glob("*.pdf"):
            destino = pasta_dest / "autos-completos.pdf"

            # Versionamento: se já existe, comparar hash
            if destino.exists():
                hash_atual = md5_arquivo(str(destino))
                hash_novo = md5_arquivo(str(pdf))
                if hash_atual == hash_novo:
                    log(f"  = {cnj}: PDF idêntico, pulando")
                    continue
                # Versionar o antigo
                data_antigo = datetime.fromtimestamp(destino.stat().st_mtime)
                backup = pasta_dest / f"autos-completos-{data_antigo.strftime('%Y-%m-%d')}.pdf"
                shutil.move(str(destino), str(backup))
                log(f"  ↻ {cnj}: versão anterior salva como {backup.name}")

                # Registrar versão na FICHA
                ficha = ler_ficha(pasta_dest)
                versoes = ficha.get("versoes", [])
                versoes.append({
                    "data": data_antigo.isoformat(),
                    "hash": hash_atual,
                    "tamanho_mb": round(backup.stat().st_size / 1048576, 1),
                    "arquivo": backup.name
                })
                ficha["versoes"] = versoes
                salvar_ficha(pasta_dest, ficha)

            shutil.move(str(pdf), str(destino))
            log(f"  → {cnj}: PDF importado")

            # Extrair texto
            txt = pasta_dest / "TEXTO-EXTRAIDO.txt"
            ok, _ = rodar(
                ["pdftotext", "-layout", str(destino), str(txt)],
                timeout=60
            )
            if ok:
                log(f"    Texto extraído ({txt.stat().st_size // 1024} KB)")

            # Atualizar FICHA.json
            ficha = ler_ficha(pasta_dest)
            ficha["data_download"] = datetime.now().isoformat()
            ficha["hash_pdf"] = md5_arquivo(str(destino))
            ficha["tamanho_pdf_mb"] = round(destino.stat().st_size / 1048576, 1)
            salvar_ficha(pasta_dest, ficha)

            importados.append({
                "cnj": cnj,
                "pasta": str(pasta_dest),
                "pdf": str(destino),
                "texto": txt.exists()
            })

        # Limpar pasta temp vazia
        if not any(item.iterdir()):
            item.rmdir()

    # Auto-renomear pastas (Perícia NN - Cidade - Vara)
    _renomear_pastas(importados)

    log(f"  {len(importados)} processos importados")
    return importados


def _renomear_pastas(importados):
    """Renomeia pastas de CNJ puro para Perícia NN - Cidade - Vara."""
    for imp in importados:
        pasta = Path(imp["pasta"])
        ficha = ler_ficha(pasta)

        # Só renomeia se o nome atual é um CNJ puro
        if not re.match(r"^\d{7}-\d{2}\.\d{4}\.\d\.\d{2}\.\d{4}$", pasta.name):
            continue

        unidade = ficha.get("unidade", "")
        cnj = ficha.get("cnj", pasta.name)

        if not unidade:
            continue

        # Extrair cidade da unidade (ex: "1ª Vara Cível de Belo Horizonte")
        cidade_match = re.search(r"(?:de|da|do)\s+(.+?)(?:\s*[-/]|$)", unidade, re.IGNORECASE)
        cidade = cidade_match.group(1).strip() if cidade_match else ""

        # Extrair vara
        vara_match = re.search(r"(\d+ª?\s*Vara[^-]*)", unidade, re.IGNORECASE)
        vara = vara_match.group(1).strip() if vara_match else unidade[:40]

        # Contar perícias existentes para numeração
        existentes = [
            d.name for d in PROCESSOS_DIR.iterdir()
            if d.is_dir() and d.name.startswith("Perícia ")
        ]
        numeros = []
        for nome in existentes:
            m = re.match(r"Perícia\s+(\d+)", nome)
            if m:
                numeros.append(int(m.group(1)))
        proximo = max(numeros, default=0) + 1

        # Montar novo nome
        if cidade:
            novo_nome = f"Perícia {proximo:02d} - {cidade} - {vara}"
        else:
            novo_nome = f"Perícia {proximo:02d} - {vara}"

        # Limitar tamanho
        if len(novo_nome) > 80:
            novo_nome = novo_nome[:77] + "..."

        novo_caminho = PROCESSOS_DIR / novo_nome
        if novo_caminho.exists():
            continue

        try:
            pasta.rename(novo_caminho)
            # Criar symlink CNJ → pasta renomeada
            symlink = PROCESSOS_DIR / cnj
            if not symlink.exists():
                symlink.symlink_to(novo_caminho)
            log(f"  📁 {cnj} → {novo_nome}")
            imp["pasta"] = str(novo_caminho)
            imp["renomeado"] = novo_nome
        except Exception as e:
            log(f"  ⚠ Falha ao renomear {cnj}: {e}", "WARN")


# ─── ETAPA 8: Relatório + Notificação ───────────────────────────────────────

def etapa_relatorio(diag, nomeacoes_aj, nomeacoes_ajg, desatualizados,
                    pendentes, resultados_download, importados, tempo_inicio):
    """Gera relatório final, atualiza status, notifica."""
    log("═══ ETAPA 8: RELATÓRIO + NOTIFICAÇÃO ═══")

    # Rodar scanner
    log("  Atualizando STATUS-PROCESSOS.json...")
    rodar(["python3", str(SCANNER), "--json-only"], timeout=60)

    # Rodar deadline monitor
    log("  Verificando prazos...")
    ok_dl, out_dl = rodar(["python3", str(DEADLINE), "--json"], timeout=30)
    alertas = []
    if ok_dl:
        try:
            dl_data = json.loads(out_dl)
            alertas = dl_data.get("alertas", [])
        except Exception:
            pass

    # Montar relatório
    tempo_total = time.time() - tempo_inicio
    relatorio = {
        "data": datetime.now().isoformat(),
        "tempo_total_seg": round(tempo_total, 1),
        "diagnostico": {
            "chrome_aj": diag.get("chrome_aj", False),
            "chrome_pje": diag.get("pode_baixar", False),
        },
        "nomeacoes_aj": len(nomeacoes_aj),
        "nomeacoes_ajg": len(nomeacoes_ajg),
        "desatualizados": len(desatualizados),
        "pendentes_download": len(pendentes),
        "downloads": {
            "tentados": len(resultados_download),
            "sucesso": sum(1 for r in resultados_download if r.get("status") == "ok"),
            "falha": sum(1 for r in resultados_download if r.get("status") == "erro"),
        },
        "importados": len(importados),
        "alertas_prazo": len(alertas),
        "alertas_criticos": sum(1 for a in alertas if a.get("nivel") == "CRITICAL"),
        "resultados_download": resultados_download,
        "importados_detalhe": importados,
    }

    # Salvar relatório
    RELATORIO_JSON.write_text(
        json.dumps(relatorio, indent=2, ensure_ascii=False),
        encoding="utf-8"
    )
    log(f"  Relatório salvo: {RELATORIO_JSON}")

    # Resumo no terminal
    log("─── RESUMO ───")
    log(f"  Tempo total: {tempo_total:.0f}s")
    log(f"  Nomeações: AJ={len(nomeacoes_aj)} | AJG={len(nomeacoes_ajg)}")
    log(f"  Desatualizados: {len(desatualizados)}")
    log(f"  Downloads: {relatorio['downloads']['sucesso']}/{relatorio['downloads']['tentados']}")
    log(f"  Importados: {len(importados)}")
    if alertas:
        criticos = [a for a in alertas if a.get("nivel") == "CRITICAL"]
        if criticos:
            log(f"  ⚠ {len(criticos)} PRAZOS CRÍTICOS!", "WARN")

    # Notificação macOS
    try:
        msg_notif = (
            f"AJ:{len(nomeacoes_aj)} AJG:{len(nomeacoes_ajg)} "
            f"Downloads:{relatorio['downloads']['sucesso']} "
            f"Alertas:{len(alertas)}"
        )
        subprocess.run([
            "osascript", "-e",
            f'display notification "{msg_notif}" '
            f'with title "Orquestrador Noturno" '
            f'subtitle "Concluído em {tempo_total:.0f}s"'
        ], timeout=5)
    except Exception:
        pass

    # Som
    try:
        subprocess.run(
            ["afplay", "/System/Library/Sounds/Glass.aiff"],
            timeout=5
        )
    except Exception:
        pass

    # Notificação Telegram
    try:
        from notificar_telegram import enviar_relatorio_noturno
        enviar_relatorio_noturno(relatorio)
        log("  Telegram notificado", "OK")
    except Exception as e:
        log(f"  Telegram falhou: {e}", "WARN")

    return relatorio


# ─── Formatação Telegram ─────────────────────────────────────────────────────

def formatar_telegram(relatorio):
    """Formata relatório para envio via Telegram."""
    r = relatorio
    dl = r["downloads"]

    linhas = [
        "*ORQUESTRADOR NOTURNO*",
        f"_{datetime.now().strftime('%d/%m %H:%M')}_",
        "",
        f"*NOMEAÇÕES:* AJ={r['nomeacoes_aj']} | AJG={r['nomeacoes_ajg']}",
        f"*DESATUALIZADOS:* {r['desatualizados']}",
        f"*DOWNLOADS:* {dl['sucesso']}/{dl['tentados']}"
        + (f" ({dl['falha']} falhas)" if dl['falha'] else ""),
        f"*IMPORTADOS:* {r['importados']}",
    ]

    if r["alertas_criticos"]:
        linhas.append(f"🔴 *{r['alertas_criticos']} PRAZOS CRÍTICOS*")

    linhas.append(f"\n_Tempo: {r['tempo_total_seg']:.0f}s_")

    return "\n".join(linhas)


# ─── Main ────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        description="Orquestrador Noturno — Stemmia Forense"
    )
    parser.add_argument("--diagnostico", action="store_true",
                        help="Só verifica pré-requisitos")
    parser.add_argument("--dry-run", action="store_true",
                        help="Simula sem baixar/mover")
    parser.add_argument("--so-consultar", action="store_true",
                        help="Só AJ+AJG (sem baixar)")
    parser.add_argument("--so-baixar", action="store_true",
                        help="Só download PJe")
    parser.add_argument("--so-atualizar", action="store_true",
                        help="Só processos desatualizados")
    parser.add_argument("--max", type=int, default=None,
                        help="Limita downloads a N")
    parser.add_argument("--json", action="store_true",
                        help="Saída JSON (para bot)")
    parser.add_argument("--importar", action="store_true",
                        help="Importa PDFs de _downloads_temp (pipeline Windows)")
    parser.add_argument("--exportar-pendentes", action="store_true",
                        help="Salva CNJs sem PDF para pipeline Windows")

    args = parser.parse_args()
    tempo_inicio = time.time()

    log("╔═══════════════════════════════════════════╗")
    log("║   ORQUESTRADOR NOTURNO — Stemmia Forense  ║")
    log("╚═══════════════════════════════════════════╝")
    log(f"  Modo: {'dry-run' if args.dry_run else 'produção'}")
    log(f"  Início: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")

    # ETAPA 1: Diagnóstico (sempre roda)
    diag = etapa_diagnostico()

    if args.diagnostico:
        diagnostico_detalhado(diag)
        if args.json:
            print(json.dumps(diag, indent=2, ensure_ascii=False))
        return

    # Modo --importar: importa PDFs baixados pelo Windows e sai
    if args.importar:
        resultado = importar_downloads_temp()
        if args.json:
            print(json.dumps(resultado, indent=2, ensure_ascii=False))
        return

    # Modo --exportar-pendentes: salva CNJs sem PDF e sai
    if args.exportar_pendentes:
        resultado = exportar_pendentes()
        if args.json:
            print(json.dumps(resultado, indent=2, ensure_ascii=False))
        return

    # Inicializar listas
    nomeacoes_aj = []
    nomeacoes_ajg = []
    desatualizados = []
    pendentes = []
    resultados_download = []
    importados = []

    # ETAPA 2+3: Consultar AJ e AJG
    if not args.so_baixar:
        if diag["pode_consultar"]:
            nomeacoes_aj = etapa_consultar_aj()
            nomeacoes_ajg = etapa_consultar_ajg()
        else:
            log("⚠ Chrome AJ não disponível — pulando consulta", "WARN")

    # ETAPA 3.5: Descoberta de novos processos (DJe + PJe Consulta Pública)
    novos_descobertos = []
    if not args.so_baixar and not args.so_consultar:
        novos_descobertos = etapa_descoberta()

    # ETAPA 4: Verificar movimentações
    if not args.so_consultar and not args.so_baixar:
        desatualizados = etapa_verificar_movimentacoes()

    # ETAPA 5: Pendentes
    if args.so_baixar:
        # Ler pendentes existentes
        pend_file = SCRIPTS_DIR / "_pendentes_download.json"
        if pend_file.exists():
            pendentes = json.loads(pend_file.read_text(encoding="utf-8"))
    elif args.so_atualizar:
        # Só desatualizados
        desatualizados = etapa_verificar_movimentacoes()
        pendentes = [{"cnj": d["cnj"], "motivo": "DESATUALIZADO"} for d in desatualizados]
    elif not args.so_consultar:
        pendentes = etapa_pendentes(nomeacoes_aj, nomeacoes_ajg, desatualizados)

    # ETAPA 6: Baixar
    if not args.so_consultar:
        resultados_download = etapa_baixar(
            pendentes, diag,
            max_downloads=args.max,
            dry_run=args.dry_run
        )

    # ETAPA 7: Importar
    if not args.so_consultar:
        importados = etapa_importar(resultados_download, dry_run=args.dry_run)

    # ETAPA 8: Relatório
    relatorio = etapa_relatorio(
        diag, nomeacoes_aj, nomeacoes_ajg, desatualizados,
        pendentes, resultados_download, importados, tempo_inicio
    )

    if args.json:
        print(json.dumps(relatorio, indent=2, ensure_ascii=False))

    log("═══ ORQUESTRADOR NOTURNO FINALIZADO ═══")


if __name__ == "__main__":
    main()
