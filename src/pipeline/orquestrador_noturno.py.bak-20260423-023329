    diag = {
        "chrome_aj": checar_porta(PORTA_AJ),
        "chrome_pje_mac": checar_porta(PORTA_PJE_MAC),
        "chrome_pje_win": False,
        "parallels": False,
        "parallels_ip": None,
        "pdftotext": shutil.which("pdftotext") is not None,
        "processos_dir": PROCESSOS_DIR.is_dir(),
        "total_processos": 0,
        "scripts_presentes": {
            "consultar_aj": CONSULTAR_AJ.exists(),
            "consultar_ajg": CONSULTAR_AJG.exists(),
            "baixar_pje": BAIXAR_PJE.exists() or BAIXAR_PJE_LOCAL.exists(),
            "scanner": SCANNER.exists(),
            "deadline": DEADLINE.exists(),
        }
    }

    # Parallels + Windows
    diag["parallels"], diag["parallels_ip"] = checar_parallels()
    if diag["parallels"] and diag["parallels_ip"]:
        ok, _ = rodar(
            ["curl", "-s", "-o", "/dev/null", "-w", "%{http_code}",
             f"http://{diag['parallels_ip']}:{PORTA_PJE_WIN}/json/version"],
            timeout=5
        )
        diag["chrome_pje_win"] = ok

    # Contagem de processos
    if PROCESSOS_DIR.is_dir():
        diag["total_processos"] = len([
            d for d in PROCESSOS_DIR.iterdir()
            if d.is_dir() and not d.name.startswith(".")
        ])

    # Resumo
    disponivel = []
    if diag["chrome_aj"]:
        disponivel.append("AJ/AJG (porta 9223)")
    if diag["chrome_pje_mac"]:
        disponivel.append("PJe Mac (porta 9224)")
    if diag["chrome_pje_win"]:
        disponivel.append(f"PJe Windows ({diag['parallels_ip']}:9222)")

    diag["disponivel"] = disponivel
    diag["pode_consultar"] = diag["chrome_aj"]
    diag["pode_baixar"] = diag["chrome_pje_mac"] or diag["chrome_pje_win"]

    for k, v in diag.items():
        if k not in ("parallels_ip", "disponivel", "scripts_presentes"):
            status = "✓" if v else "✗"
            log(f"  {status} {k}: {v}")

    if disponivel:
        log(f"  Disponível: {', '.join(disponivel)}")
    else:
        log("  ⚠ Nenhum Chrome CDP detectado", "WARN")

    return diag


# ─── ETAPA 2: Consultar AJ TJMG ─────────────────────────────────────────────

def etapa_consultar_aj():
    """Consulta nomeações pendentes no AJ TJMG."""
    log("═══ ETAPA 2: CONSULTAR AJ TJMG ═══")

    ok, out = rodar(
        ["python3", str(CONSULTAR_AJ), "--pendentes", "--json"],
        timeout=60
    )
    if not ok:
        log(f"Erro ao consultar AJ: {out[:200]}", "ERROR")
        return []

    try:
        nomeacoes = json.loads(out)
        if isinstance(nomeacoes, dict):
            nomeacoes = nomeacoes.get("nomeacoes", [])
    except json.JSONDecodeError:
        log("Resposta do AJ não é JSON válido", "ERROR")
        return []

    log(f"  AJ: {len(nomeacoes)} nomeações pendentes")

    # Criar pastas para novas nomeações
    for nom in nomeacoes:
        cnj = nom.get("numero_processo_cnj", "")
        if not cnj:
            continue
        pasta = PROCESSOS_DIR / cnj
        if not pasta.exists():
            pasta.mkdir(parents=True, exist_ok=True)
            ficha = {
                "cnj": cnj,
                "origem": "AJ",
                "sistema": "AJ-TJMG",
                "nomeacao": nom.get("numero_nomeacao", ""),
                "unidade": nom.get("unidade", ""),
                "data_nomeacao": nom.get("data_nomeacao", ""),
                "valor_honorario": nom.get("valor_honorario", ""),
                "situacao": nom.get("situacao", ""),
                "data_criacao": datetime.now().isoformat(),
                "criado_por": "orquestrador_noturno"
            }
            salvar_ficha(pasta, ficha)
            log(f"  + Nova pasta: {cnj}")
        nom["_origem"] = "AJ"

