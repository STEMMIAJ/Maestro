# MAIN
# ============================================================

def parse_args():
    parser = argparse.ArgumentParser(description="Hub de Automações — Stemmia Forense")
    parser.add_argument("--discovery-only", action="store_true")
    parser.add_argument("--status-only", action="store_true")
    parser.add_argument("--dashboard-only", action="store_true")
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("--no-telegram", action="store_true")
    parser.add_argument("--no-ftp", action="store_true")
    parser.add_argument("--dias-dje", type=int, default=DJE_DIAS_PADRAO)
    return parser.parse_args()


def main():
    args = parse_args()
    logger = setup_logging()
    inicio = time.time()

    logger.info("=" * 44)
    logger.info("  HUB DE AUTOMAÇÕES — STEMMIA")
    logger.info(f"  {datetime.now().strftime('%d/%m/%Y %H:%M:%S')}")
    logger.info("=" * 44)

    estado = {
        "timestamp": datetime.now().isoformat(),
        "fontes": {},
        "descobertas_novas": [],
        "movimentacoes_novas": [],
        "processos": {},
        "historico": [],
    }

    try:
        if args.dashboard_only:
            if ESTADO_PATH.exists():
                with open(ESTADO_PATH, encoding="utf-8") as f:
                    estado = json.load(f)
            fase_saida(estado, args, logger, inicio)
            return

        if not args.status_only:
            fase_descoberta(estado, logger, dias_dje=args.dias_dje)

        if not args.discovery_only:
            fase_status(estado, logger, dry_run=args.dry_run)

        if not args.discovery_only and not args.status_only:
            fase_consolidacao(estado, logger)

        fase_saida(estado, args, logger, inicio)

    except Exception as e:
        logger.error(f"Erro fatal: {e}")
        traceback.print_exc()
        sys.exit(1)

    logger.info(f"Concluído em {time.time() - inicio:.1f}s")


if __name__ == "__main__":
    main()
