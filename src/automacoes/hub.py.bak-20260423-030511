# FIX: carregar .env (STEMMIA_PERITO_CPF / STEMMIA_PERITO_NOMES etc.)
# Nao sobrescreve env vars ja setadas. Defaults seguros em --dry-run.
def _carregar_env_inicial():
    for env_path in (PROJECT_ROOT / ".env", Path.home() / ".stemmia-env"):
        if not env_path.exists():
            continue
        try:
            for linha in env_path.read_text(encoding="utf-8").splitlines():
                linha = linha.strip()
                if not linha or linha.startswith("#") or "=" not in linha:
                    continue
                chave, _, valor = linha.partition("=")
                chave = chave.strip()
                valor = valor.strip().strip('"').strip("'")
                if chave and chave not in os.environ:
                    os.environ[chave] = valor
        except Exception:
            pass
    # Defaults seguros se ainda ausentes (config_hub.PERITO_* cobre valores reais)
    if "--dry-run" in sys.argv:
        os.environ.setdefault("STEMMIA_PERITO_CPF", "12785885660")
