# FASE 1: DESCOBERTA
# ============================================================

def fase_descoberta(estado, logger, dias_dje=DJE_DIAS_PADRAO):
    logger.info("=== FASE 1: DESCOBERTA ===")

    if not _HAS_DESCOBRIR:
        logger.error(f"descobrir_processos indisponível: {_DESCOBRIR_ERR}")
        for f_id in ["dje_tjmg", "pje_consulta", "datajud"]:
            estado["fontes"][f_id] = {
                "status": "erro", "resultados": 0,
                "ultima_execucao": datetime.now().isoformat(),
                "erro": f"Import falhou: {_DESCOBRIR_ERR}",
            }
        return

    resultados_fontes = []

    with ThreadPoolExecutor(max_workers=2) as executor:
        futures = {}
        fonte_dje = next((f for f in FONTES if f["id"] == "dje_tjmg"), None)
        if fonte_dje and fonte_dje["ativa"]:
            futures[executor.submit(fonte_dje_tjmg, dias_dje)] = "dje_tjmg"

        fonte_pje = next((f for f in FONTES if f["id"] == "pje_consulta"), None)
        if fonte_pje and fonte_pje["ativa"]:
            futures[executor.submit(fonte_pje_consulta_publica)] = "pje_consulta"

        for future in as_completed(futures):
            fonte_id = futures[future]
            try:
                resultado = future.result(timeout=120)
                resultados_fontes.append(resultado)
                estado["fontes"][fonte_id] = {
                    "status": "ok" if not resultado.get("erro") else "erro",
                    "resultados": len(resultado.get("cnjs", [])),
                    "ultima_execucao": datetime.now().isoformat(),
                    "erro": resultado.get("erro"),
                }
                logger.info(f"  {fonte_id}: {len(resultado.get('cnjs', []))} CNJs")
            except Exception as e:
                logger.error(f"  {fonte_id}: {e}")
                estado["fontes"][fonte_id] = {
                    "status": "erro", "resultados": 0,
                    "ultima_execucao": datetime.now().isoformat(),
                    "erro": str(e),
                }

    # DataJud enriquecimento
    todos_cnjs_novos = set()
    for r in resultados_fontes:
        todos_cnjs_novos.update(r.get("cnjs", []))

    cnjs_conhecidos = carregar_cnjs_conhecidos()
    novos_cnjs = todos_cnjs_novos - cnjs_conhecidos

    datajud_dados = {}
    if novos_cnjs and _HAS_DATAJUD:
        try:
            datajud_dados = fonte_datajud_enriquecer(list(novos_cnjs))
            estado["fontes"]["datajud"] = {
                "status": "ok",
                "resultados": len(datajud_dados),
                "ultima_execucao": datetime.now().isoformat(),
                "erro": None,
            }
        except Exception as e:
            logger.error(f"  DataJud enriquecimento: {e}")
            estado["fontes"]["datajud"] = {
                "status": "erro", "resultados": 0,
                "ultima_execucao": datetime.now().isoformat(),
                "erro": str(e),
            }
    elif not novos_cnjs:
        estado["fontes"]["datajud"] = {
            "status": "ok", "resultados": 0,
            "ultima_execucao": datetime.now().isoformat(),
            "erro": None,
        }

    # Reconciliar
    try:
        consolidado = reconciliar(resultados_fontes, datajud_dados, cnjs_conhecidos)
        estado["descobertas_novas"] = [
            {
                "cnj": cnj,
                "fontes": [r["fonte"] for r in resultados_fontes if cnj in r.get("cnjs", [])],
                "classe": datajud_dados.get(cnj, {}).get("classe", ""),
                "orgao_julgador": datajud_dados.get(cnj, {}).get("orgaoJulgador", ""),
                "data_descoberta": datetime.now().strftime("%Y-%m-%d"),
            }
            for cnj in consolidado.get("novos_cnjs", [])
        ]
        logger.info(f"  Reconciliado: {consolidado['total']} total, {consolidado['novos']} novos")
    except Exception as e:
        logger.error(f"  Reconciliação: {e}")

    # Comunica PJe
    fonte_comunica = next((f for f in FONTES if f["id"] == "comunica_pje"), None)
    if fonte_comunica and fonte_comunica.get("ativa"):
        try:
            import importlib.util
            _spec = importlib.util.spec_from_file_location(
                "comunica_pje",
                str(PROJECT_ROOT / "src" / "pje" / "monitor-publicacoes" / "comunica_pje.py"),
            )
            _mod = importlib.util.module_from_spec(_spec)
            _spec.loader.exec_module(_mod)
            executar_para_hub = _mod.executar_para_hub
            resultado_comunica = executar_para_hub()
            estado["fontes"]["comunica_pje"] = resultado_comunica
            logger.info(f"  Comunica PJe: {resultado_comunica.get('confirmados', 0)} confirmados, {resultado_comunica.get('possiveis', 0)} possíveis")
        except Exception as e:
            logger.error(f"  Comunica PJe: {e}")
            estado["fontes"]["comunica_pje"] = {
                "status": "erro", "resultados": 0,
                "ultima_execucao": datetime.now().isoformat(),
                "erro": str(e),
            }
    elif fonte_comunica:
        estado["fontes"]["comunica_pje"] = {
            "status": "desativada", "resultados": 0,
            "ultima_execucao": None,
            "erro": fonte_comunica.get("motivo_inativa"),
        }


