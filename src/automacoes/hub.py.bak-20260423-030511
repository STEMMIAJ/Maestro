def fase_status(estado, logger, dry_run=False):
    logger.info("=== FASE 2: STATUS ===")

    # FIX: DataJud CNJ entra em timeout infinito em dry-run.
    # Pular fase inteira quando --dry-run.
    if dry_run:
        logger.warning("  [DRY RUN] Fase 2 pulada (DataJud CNJ costuma travar com timeouts)")
        return

    if not _HAS_DATAJUD:
        logger.error(f"datajud_client indisponível: {_DATAJUD_ERR}")
        return

    processos_ativos = []
    if CONSOLIDADO_JSON.exists():
        try:
            with open(CONSOLIDADO_JSON, encoding="utf-8") as f:
                dados = json.load(f)
            lista = dados.get("processos", dados) if isinstance(dados, dict) else dados
            processos_ativos = [
                p for p in lista if isinstance(p, dict)
                and p.get("etapa_pipeline") not in ("EXPIRADO", "CANCELADO", "RECUSADO")
            ]
        except (json.JSONDecodeError, KeyError):
            pass

    if not processos_ativos:
        logger.info("  Nenhum processo ativo para verificar")
        return

    # Estado anterior
    estado_anterior = {}
    if ESTADO_PATH.exists():
        try:
            with open(ESTADO_PATH, encoding="utf-8") as f:
                old = json.load(f)
            for m in old.get("movimentacoes_novas", []):
                estado_anterior[m["cnj"]] = m.get("total_movimentos", 0)
        except (json.JSONDecodeError, KeyError):
            pass

    movimentacoes_novas = []
    cnjs_verificados = 0

    for proc in processos_ativos:
        cnj = proc.get("cnj", "")
        if not cnj:
            continue
        try:
            movs = buscar_movimentacoes(cnj, dias=DATAJUD_DIAS_MOVIMENTACAO)
            cnjs_verificados += 1
            if movs:
                ultima = movs[0]
                total_anterior = estado_anterior.get(cnj, 0)
                total_atual = len(movs)
                if total_atual > total_anterior or total_anterior == 0:
                    movimentacoes_novas.append({
                        "cnj": cnj,
                        "cidade": proc.get("cidade", ""),
                        "vara": proc.get("vara", proc.get("orgao_julgador", "")),
                        "ultima_movimentacao": ultima.get("nome", ""),
                        "data_movimentacao": ultima.get("data", ""),
                        "total_movimentos": total_atual,
                        "delta": total_atual - total_anterior if total_anterior > 0 else 0,
                    })
            time.sleep(0.3)
        except Exception as e:
            logger.warning(f"  Erro {cnj}: {e}")

    estado["movimentacoes_novas"] = movimentacoes_novas

    if "datajud" not in estado["fontes"]:
        estado["fontes"]["datajud"] = {}
    estado["fontes"]["datajud"].update({
        "status": "ok", "resultados": cnjs_verificados,
        "ultima_execucao": datetime.now().isoformat(), "erro": None,
    })

    logger.info(f"  Verificados: {cnjs_verificados} | Novidades: {len(movimentacoes_novas)}")


# ============================================================
# FASE 3: CONSOLIDAÇÃO
# ============================================================

def fase_consolidacao(estado, logger):
    logger.info("=== FASE 3: CONSOLIDAÇÃO ===")

    if not _HAS_CONSOLIDAR:
        logger.error(f"consolidar_processos indisponível: {_CONSOLIDAR_ERR}")
        return

    try:
        processos = consolidar_tudo()
        stats = estatisticas(processos)
        salvar_consolidado(processos, stats)
        estado["processos"] = {
            "total": stats.get("total", 0),
            "por_situacao": stats.get("por_situacao", {}),
            "por_etapa": stats.get("por_etapa", {}),
            "por_cidade": stats.get("por_cidade", {}),
            "alertas": stats.get("alertas", []),
        }
        logger.info(f"  Consolidado: {stats.get('total', 0)} processos")
    except Exception as e:
        logger.error(f"  Consolidação: {e}")
        traceback.print_exc()


# ============================================================
# FASE 4: SAÍDA
# ============================================================

def fase_saida(estado, args, logger, inicio):
    logger.info("=== FASE 4: SAÍDA ===")

    duracao = time.time() - inicio
    estado["duracao_segundos"] = round(duracao, 1)
    _atualizar_historico(estado)

    if args.dry_run:
        logger.info("  [DRY RUN] Estado não salvo")
        print(json.dumps(estado, ensure_ascii=False, indent=2))
        return

    # Salvar estado
    AUTOMACOES_DIR.mkdir(parents=True, exist_ok=True)
    with open(ESTADO_PATH, "w", encoding="utf-8") as f:
        json.dump(estado, f, ensure_ascii=False, indent=2)
    logger.info(f"  Estado salvo: {ESTADO_PATH}")

    # Gerar dashboard
    try:
        gerar_script = AUTOMACOES_DIR / "gerar_dashboard_hub.py"
        if gerar_script.exists():
            subprocess.run(
                [sys.executable, str(gerar_script)],
                cwd=str(AUTOMACOES_DIR), timeout=60, check=True,
            )
            logger.info(f"  Dashboard gerado: {DASHBOARD_PATH}")
        else:
            logger.warning("  gerar_dashboard_hub.py não encontrado")
    except subprocess.CalledProcessError as e:
        logger.error(f"  Dashboard: {e}")

    # FTP
    if not args.no_ftp:
        _upload_ftp(logger)

    # Telegram
    if not args.no_telegram:
        _enviar_telegram(estado, logger)


def _atualizar_historico(estado):
    historico = []
    if ESTADO_PATH.exists():
        try:
            with open(ESTADO_PATH, encoding="utf-8") as f:
                old = json.load(f)
            historico = old.get("historico", [])
        except (json.JSONDecodeError, KeyError):
            pass

    hoje = datetime.now().strftime("%Y-%m-%d")
    entrada = {
        "data": hoje,
        "novos": len(estado.get("descobertas_novas", [])),
        "movimentacoes": len(estado.get("movimentacoes_novas", [])),
        "alertas": len(estado.get("processos", {}).get("alertas", [])),
        "fontes_ok": sum(1 for f in estado.get("fontes", {}).values() if f.get("status") == "ok"),
        "fontes_total": len(estado.get("fontes", {})),
        "status": "ok" if all(
            f.get("status") in ("ok", "desativada") for f in estado.get("fontes", {}).values()
        ) else "parcial",
    }
    historico = [h for h in historico if h.get("data") != hoje]
    historico.insert(0, entrada)
    estado["historico"] = historico[:HISTORICO_MAX_DIAS]


def _upload_ftp(logger):
    if not DASHBOARD_PATH.exists():
        logger.warning("  Dashboard inexistente, pulando FTP")
        return
    try:
        ftp_pass = os.environ.get("FTP_PASSWORD", "")
        if not ftp_pass:
            token_path = Path.home() / ".ftp-password"
            if token_path.exists():
                ftp_pass = token_path.read_text(encoding="utf-8").strip()
        if not ftp_pass:
            logger.warning("  Senha FTP não configurada")
            return
        import ftplib
        ftp = ftplib.FTP()
        ftp.connect(FTP_HOST, 21, timeout=30)
        ftp.login(FTP_USER, ftp_pass)
        ftp.cwd(FTP_REMOTE_DIR)
        with open(DASHBOARD_PATH, "rb") as f:
            ftp.storbinary(f"STOR {FTP_DASHBOARD_FILENAME}", f)
        ftp.quit()
        logger.info(f"  FTP OK: {FTP_DASHBOARD_FILENAME}")
    except Exception as e:
        logger.error(f"  FTP: {e}")


def _enviar_telegram(estado, logger):
    if not _HAS_TELEGRAM:
        logger.warning("  Telegram indisponível")
        return

    fontes = estado.get("fontes", {})
    fontes_str = " | ".join(
        f"{f['nome']} {'✓' if fontes.get(f['id'], {}).get('status') == 'ok' else '—' if fontes.get(f['id'], {}).get('status') == 'desativada' else '✗'}"
        for f in FONTES
    )
    novos = len(estado.get("descobertas_novas", []))
    movs = len(estado.get("movimentacoes_novas", []))
    alertas = len(estado.get("processos", {}).get("alertas", []))

    linhas = [
        f"*HUB AUTOMAÇÃO — {datetime.now().strftime('%d/%m %H:%M')}*",
        f"Fontes: {fontes_str}",
        f"Novos: {novos} | Movimentações: {movs} | Alertas: {alertas}",
    ]
    for m in estado.get("movimentacoes_novas", [])[:5]:
        cnj_short = m["cnj"][-9:]
        linhas.append(f"  `{cnj_short}`: {m['ultima_movimentacao'][:40]} ({m['data_movimentacao']})")

    linhas.append(f"\n[Dashboard](https://stemmia.com.br/webdev/teste/{FTP_DASHBOARD_FILENAME})")
    try:
        telegram_enviar("\n".join(linhas))
        logger.info("  Telegram enviado")
    except Exception as e:
        logger.error(f"  Telegram: {e}")


